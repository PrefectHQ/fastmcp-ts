{
  "name": "@prefecthq/fastmcp-ts",
  "version": "0.0.6",
  "description": "🏎️  The official FastMCP TypeScript library - build MCP servers and clients, fast 🏎️",
  "type": "module",
  "exports": {
    "./server": {
      "types": "./dist/server.d.ts",
      "import": "./dist/server.js"
    },
    "./client": {
      "types": "./dist/client.d.ts",
      "import": "./dist/client.js"
    }
  },
  "browser": {
    "child_process": false,
    "node:child_process": false,
    "fs": false,
    "fs/promises": false,
    "node:fs": false,
    "node:fs/promises": false,
    "http": false,
    "node:http": false,
    "https": false,
    "node:https": false,
    "os": false,
    "node:os": false,
    "path": false,
    "node:path": false,
    "node:url": false,
    "node:process": false,
    "node:stream": false,
    "net": false,
    "node:net": false,
    "tls": false,
    "node:tls": false,
    "@modelcontextprotocol/client/stdio": false
  },
  "sideEffects": false,
  "bin": {
    "fastmcp": "dist/cli/index.cjs"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "tsup",
    "prepublishOnly": "npm run build && node scripts/test-dist.mjs && npm run test:browser-bundle",
    "test": "vitest run",
    "test:browser-bundle": "node scripts/test-browser-bundle.mjs",
    "test:e2e": "playwright test",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "docs:dev": "cd docs && npx --yes mint@latest dev",
    "docs:api": "typedoc && node scripts/generate-api-nav.mjs",
    "docs:links": "cd docs && npx --yes mint@latest broken-links",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "changeset publish"
  },
  "devDependencies": {
    "@anthropic-ai/sdk": "^0.91.1",
    "@changesets/cli": "^2.31.0",
    "@google/genai": "^1.50.1",
    "@playwright/test": "^1.61.1",
    "@types/node": "^22.0.0",
    "@types/url-template": "^2.0.31",
    "@vitest/coverage-v8": "^4.1.8",
    "arktype": "^2.2.0",
    "esbuild": "^0.28.1",
    "execa": "^9.6.1",
    "fake-indexeddb": "^6.2.5",
    "get-bin-path": "^11.0.1",
    "jsdom": "^29.1.1",
    "openai": "^6.34.0",
    "tsup": "^8.5.1",
    "tsx": "^4.21.0",
    "typedoc": "^0.28.0",
    "typedoc-plugin-markdown": "^4.12.0",
    "typescript": "^5.0.0",
    "valibot": "^1.3.1",
    "vitest": "^4.1.8",
    "zod": "^4.3.6"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/PrefectHQ/fastmcp-ts.git"
  },
  "keywords": [
    "mcp",
    "mcp-tools",
    "fastmcp",
    "mcp-clients",
    "llms",
    "model-context-protocol",
    "mcp-servers",
    "typescript"
  ],
  "author": "prefecthq",
  "license": "Apache-2.0",
  "bugs": {
    "url": "https://github.com/PrefectHQ/fastmcp-ts/issues"
  },
  "homepage": "https://github.com/PrefectHQ/fastmcp-ts#readme",
  "peerDependencies": {
    "@anthropic-ai/sdk": ">=0.39",
    "@google/genai": ">=0.7",
    "openai": ">=4"
  },
  "peerDependenciesMeta": {
    "@anthropic-ai/sdk": {
      "optional": true
    },
    "openai": {
      "optional": true
    },
    "@google/genai": {
      "optional": true
    }
  },
  "dependencies": {
    "@clack/prompts": "^1.2.0",
    "@modelcontextprotocol/client": "2.0.0-beta.5",
    "@modelcontextprotocol/core": "2.0.0-beta.5",
    "@modelcontextprotocol/node": "2.0.0-beta.5",
    "@modelcontextprotocol/server": "2.0.0-beta.5",
    "@modelcontextprotocol/server-legacy": "2.0.0-beta.5",
    "@standard-schema/spec": "^1.1.0",
    "@types/express": "^5.0.6",
    "chalk": "^5.6.2",
    "chokidar": "^5.0.0",
    "citty": "^0.2.2",
    "cli-table3": "^0.6.5",
    "express": "^5.2.1",
    "fastest-levenshtein": "^1.0.16",
    "jose": "6.2.2",
    "listr2": "^10.2.1",
    "url-template": "^3.1.1",
    "yaml": "^2.8.3"
  }
}
