{
  "name": "@prefecthq/fastmcp-ts",
  "version": "0.0.1",
  "description": "🏎️  The official FastMCP TypeScript library - build MCP servers and clients, fast 🏎️",
  "type": "module",
  "exports": {
    "./server": {
      "types": "./dist/server.d.ts",
      "import": "./dist/server.js"
    },
    "./client": {
      "types": "./dist/client.d.ts",
      "import": "./dist/client.js"
    }
  },
  "bin": {
    "fastmcp": "./dist/cli/index.cjs"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "tsup",
    "prepublishOnly": "npm run build",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "release": "np --tag alpha"
  },
  "np": {
    "branch": "main",
    "testScript": "test",
    "release": true
  },
  "devDependencies": {
    "@anthropic-ai/sdk": "^0.90.0",
    "@google/genai": "^1.50.1",
    "@types/node": "^22.0.0",
    "@types/url-template": "^2.0.31",
    "@vitest/coverage-v8": "^3.0.0",
    "arktype": "^2.2.0",
    "execa": "^9.6.1",
    "get-bin-path": "^11.0.1",
    "np": "^11.2.0",
    "openai": "^6.34.0",
    "tsup": "^8.5.1",
    "tsx": "^4.21.0",
    "typescript": "^5.0.0",
    "valibot": "^1.3.1",
    "vitest": "^3.0.0",
    "zod": "^4.3.6"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/PrefectHQ/fastmcp-ts.git"
  },
  "keywords": [
    "mcp",
    "mcp-tools",
    "fastmcp",
    "mcp-clients",
    "llms",
    "model-context-protocol",
    "mcp-servers",
    "typescript"
  ],
  "author": "prefecthq",
  "license": "Apache-2.0",
  "bugs": {
    "url": "https://github.com/PrefectHQ/fastmcp-ts/issues"
  },
  "homepage": "https://github.com/PrefectHQ/fastmcp-ts#readme",
  "peerDependencies": {
    "@anthropic-ai/sdk": ">=0.39",
    "@google/genai": ">=0.7",
    "openai": ">=4"
  },
  "peerDependenciesMeta": {
    "@anthropic-ai/sdk": {
      "optional": true
    },
    "openai": {
      "optional": true
    },
    "@google/genai": {
      "optional": true
    }
  },
  "dependencies": {
    "@clack/prompts": "^1.2.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@standard-schema/spec": "^1.1.0",
    "@types/express": "^5.0.6",
    "chalk": "^5.6.2",
    "chokidar": "^5.0.0",
    "citty": "^0.2.2",
    "cli-table3": "^0.6.5",
    "express": "^5.2.1",
    "fastest-levenshtein": "^1.0.16",
    "jose": "6.2.2",
    "listr2": "^10.2.1",
    "url-template": "^3.1.1",
    "yaml": "^2.8.3"
  }
}
