{
  "name": "fastmcp-ts",
  "version": "0.0.1",
  "description": "🏎️  The official FastMCP TypeScript library - build MCP servers and clients, fast 🏎️",
  "type": "module",
  "main": "dist/index.js",
  "exports": {
    "./server": {
      "types": "./dist/server.d.ts",
      "import": "./dist/server.js"
    },
    "./client": {
      "types": "./dist/client.d.ts",
      "import": "./dist/client.js"
    }
  },
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@vitest/coverage-v8": "^3.0.0",
    "tsup": "^8.5.1",
    "typescript": "^5.0.0",
    "vitest": "^3.0.0",
    "zod": "^4.3.6"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/PrefectHQ/fastmcp-ts.git"
  },
  "keywords": [
    "mcp",
    "mcp-tools",
    "fastmcp",
    "mcp-clients",
    "llms",
    "model-context-protocol",
    "mcp-servers",
    "typescript"
  ],
  "author": "prefecthq",
  "license": "Apache-2.0",
  "bugs": {
    "url": "https://github.com/PrefectHQ/fastmcp-ts/issues"
  },
  "homepage": "https://github.com/PrefectHQ/fastmcp-ts#readme",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@standard-schema/spec": "^1.1.0",
    "jose": "6.2.2"
  }
}
